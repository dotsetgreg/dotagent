.nh
.TH "DOTAGENT" "1" "Feb 2026" "dotagent" ""

.SH NAME
.PP
dotagent-toolpacks-show - Show resolved manifest metadata


.SH SYNOPSIS
.PP
\fBdotagent toolpacks show  [flags]\fP


.SH DESCRIPTION
.PP
Show resolved manifest metadata


.SH OPTIONS
.PP
\fB-h\fP, \fB--help\fP[=false]
	help for show


.SH OPTIONS INHERITED FROM PARENT COMMANDS
.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances


.SH EXAMPLE
.EX
  dotagent toolpacks show github-cli
.EE


.SH SEE ALSO
.PP
\fBdotagent-toolpacks(1)\fP
