.nh
.TH "DOTAGENT" "1" "Feb 2026" "dotagent" ""

.SH NAME
.PP
dotagent-runtime-logs - Stream runtime logs


.SH SYNOPSIS
.PP
\fBdotagent runtime logs [flags]\fP


.SH DESCRIPTION
.PP
Stream runtime logs


.SH OPTIONS
.PP
\fB-f\fP, \fB--follow\fP[=true]
	Follow logs

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for logs

.PP
\fB--tail\fP=200
	Line count from end of logs


.SH OPTIONS INHERITED FROM PARENT COMMANDS
.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances


.SH SEE ALSO
.PP
\fBdotagent-runtime(1)\fP
