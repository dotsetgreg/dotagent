.TH "DOTAGENT" "1" "Feb 2026" "dotagent" ""

.SH NAME
.PP
dotagent - Instance-based AI agent runtime with Docker-first operations


.SH SYNOPSIS
.PP
\fBdotagent [flags]\fP


.SH DESCRIPTION
.PP
dotagent is an operator-focused, instance-scoped AI agent runtime.

.PP
Use init/doctor/runtime/config/backup commands for production lifecycle operations.
Use agent/gateway in dev mode only.


.SH OPTIONS
.PP
\fB-h\fP, \fB--help\fP[=false]
	help for dotagent

.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances

.PP
\fB-v\fP, \fB--version\fP[=false]
	Show build/version metadata


.SH SEE ALSO
.PP
\fBdotagent-agent(1)\fP, \fBdotagent-backup(1)\fP, \fBdotagent-config(1)\fP, \fBdotagent-cron(1)\fP, \fBdotagent-doctor(1)\fP, \fBdotagent-gateway(1)\fP, \fBdotagent-init(1)\fP, \fBdotagent-migrate(1)\fP, \fBdotagent-runtime(1)\fP, \fBdotagent-skills(1)\fP, \fBdotagent-toolpacks(1)\fP, \fBdotagent-version(1)\fP
