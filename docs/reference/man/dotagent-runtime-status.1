.nh
.TH "DOTAGENT" "1" "Feb 2026" "dotagent" ""

.SH NAME
.PP
dotagent-runtime-status - Show runtime + readiness status


.SH SYNOPSIS
.PP
\fBdotagent runtime status [flags]\fP


.SH DESCRIPTION
.PP
Show runtime + readiness status


.SH OPTIONS
.PP
\fB--check\fP[=false]
	Exit non-zero when runtime is not ready

.PP
\fB--format\fP="text"
	Output format: text|json

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for status


.SH OPTIONS INHERITED FROM PARENT COMMANDS
.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances


.SH SEE ALSO
.PP
\fBdotagent-runtime(1)\fP
