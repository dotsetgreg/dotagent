.TH "DOTAGENT" "1" "Feb 2026" "dotagent" ""

.SH NAME
.PP
dotagent-config-path - Print active config path


.SH SYNOPSIS
.PP
\fBdotagent config path [flags]\fP


.SH DESCRIPTION
.PP
Print active config path


.SH OPTIONS
.PP
\fB-h\fP, \fB--help\fP[=false]
	help for path


.SH OPTIONS INHERITED FROM PARENT COMMANDS
.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances


.SH SEE ALSO
.PP
\fBdotagent-config(1)\fP
