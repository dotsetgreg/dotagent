.TH "DOTAGENT" "1" "Feb 2026" "dotagent" ""

.SH NAME
.PP
dotagent-runtime-restart - Restart the gateway runtime container


.SH SYNOPSIS
.PP
\fBdotagent runtime restart [flags]\fP


.SH DESCRIPTION
.PP
Restart the gateway runtime container


.SH OPTIONS
.PP
\fB-h\fP, \fB--help\fP[=false]
	help for restart


.SH OPTIONS INHERITED FROM PARENT COMMANDS
.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances


.SH SEE ALSO
.PP
\fBdotagent-runtime(1)\fP
