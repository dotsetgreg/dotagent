.SH NAME
.PP
dotagent-runtime - Manage Docker runtime lifecycle for an instance


.SH SYNOPSIS
.PP
\fBdotagent runtime [flags]\fP


.SH DESCRIPTION
.PP
Manage Docker runtime lifecycle for an instance


.SH OPTIONS
.PP
\fB-h\fP, \fB--help\fP[=false]
	help for runtime


.SH OPTIONS INHERITED FROM PARENT COMMANDS
.PP
\fB--instance\fP="default"
	Instance ID under ~/.dotagent/instances


.SH SEE ALSO
.PP
\fBdotagent(1)\fP, \fBdotagent-runtime-down(1)\fP, \fBdotagent-runtime-logs(1)\fP, \fBdotagent-runtime-ps(1)\fP, \fBdotagent-runtime-restart(1)\fP, \fBdotagent-runtime-status(1)\fP, \fBdotagent-runtime-up(1)\fP
